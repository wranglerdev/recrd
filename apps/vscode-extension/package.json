{
  "name": "recrd",
  "displayName": "recrd",
  "description": "E2E Test Recorder and Robot Framework Compiler",
  "version": "0.1.0",
  "publisher": "wranglerdev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "recrd.showInfo",
        "title": "recrd: Show Status Info"
      },
      {
        "command": "recrd.start",
        "title": "recrd: Start Recording"
      },
      {
        "command": "recrd.stop",
        "title": "recrd: Stop Recording"
      },
      {
        "command": "recrd.compile",
        "title": "recrd: Compile Session"
      },
      {
        "command": "recrd.showPreview",
        "title": "recrd: Show Live Preview",
        "icon": "$(preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "recrd.showPreview",
          "when": "resourceExtname == .recrd",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "recrd.compile",
          "when": "resourceExtname == .recrd",
          "group": "recrd"
        }
      ]
    },
    "configuration": {
      "title": "recrd",
      "properties": {
        "recrd.executablePath": {
          "type": "string",
          "default": "recrd",
          "description": "Path to the recrd CLI executable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --minify",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0"
  }
}
